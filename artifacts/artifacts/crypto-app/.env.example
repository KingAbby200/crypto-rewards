# Port Vite dev server listens on (default: 3000)
PORT=3000

# Base path for the app (default: /)
BASE_PATH=/

# Port of the local API server to proxy /api requests to (default: 8080)
API_PORT=8080

# (Production only) Full base URL of your deployed API server.
# Set this when deploying to Vercel and hosting the API separately.
# Example: https://your-api.railway.app
# Leave empty for local dev (Vite proxy handles /api automatically).
VITE_API_BASE_URL=
